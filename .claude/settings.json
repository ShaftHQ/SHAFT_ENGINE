{
  "extraKnownMarketplaces": {
    "anthropics/knowledge-work-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/knowledge-work-plugins"
      }
    },
    "anthropics/skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "enabledPlugins": {
    "jdtls-lsp@claude-plugins-official": true,
    "design@anthropics/knowledge-work-plugins": true,
    "frontend-design@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "example-skills@anthropics/skills": true
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git log *)",
      "Bash(git rev-parse *)",
      "Bash(git worktree list)",
      "Bash(rg *)",
      "Bash(py -3 scripts/ci/validate_agent_setup.py)",
      "Bash(python3 scripts/ci/validate_agent_setup.py)",
      "Bash(py -3 scripts/ci/local_gate.py *)",
      "Bash(python3 scripts/ci/local_gate.py *)",
      "Bash(python3 .claude/hooks/guard.py *)",
      "Bash(py -3 .claude/hooks/guard.py *)",
      "Bash(python3 tools/repository-map/resolve_graph_out.py *)",
      "Bash(memory load *)",
      "Bash(memory search *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/guard.py"],
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/guard.py", "--session-start"],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
