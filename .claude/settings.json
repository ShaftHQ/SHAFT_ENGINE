  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|Read|Grep|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard.py"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard.py",
              "--session-start"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "jdtls-lsp@claude-plugins-official": true,
    "design@anthropics/knowledge-work-plugins": true,
    "frontend-design@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "example-skills@anthropics/skills": true,
    "fable@fable-method": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
