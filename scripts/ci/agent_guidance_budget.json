{
  "file_budgets": {
    "AGENTS.md": {
      "max_bytes": 6528
    },
    "CLAUDE.md": {
      "max_bytes": 1536,
      "max_lines": 40
    },
    ".github/copilot-instructions.md": {
      "max_chars": 1500
    },
    ".github/instructions/framework-source.instructions.md": {
      "max_chars": 3999
    },
    ".github/instructions/java-tests.instructions.md": {
      "max_chars": 3999
    },
    "shaft-mcp/.github/copilot-instructions.md": {
      "max_chars": 1500
    }
  },
  "host_contexts": {
    "codex": [
      "AGENTS.md"
    ],
    "claude": [
      "AGENTS.md",
      "CLAUDE.md"
    ],
    "copilot": [
      "AGENTS.md",
      ".github/copilot-instructions.md",
      ".github/instructions/framework-source.instructions.md",
      ".github/instructions/java-tests.instructions.md"
    ]
  },
  "host_skill_metadata_globs": {
    "codex": [
      ".agents/skills/*/SKILL.md"
    ],
    "claude": [
      ".agents/skills/*/SKILL.md",
      ".claude/skills/*/SKILL.md"
    ]
  },
  "max_estimated_tokens_per_host": 2900,
  "active_guidance_globs": [
    "AGENTS.md",
    "CLAUDE.md",
    ".agents/skills/*/SKILL.md",
    ".agents/skills/*/agents/openai.yaml",
    ".claude/skills/*/SKILL.md",
    ".github/copilot-instructions.md",
    ".github/instructions/*.instructions.md",
    ".github/skills/*/SKILL.md"
  ],
  "total_guidance_globs": [
    "AGENTS.md",
    "CLAUDE.md",
    ".agents/skills/*/SKILL.md",
    ".claude/skills/*/SKILL.md",
    ".github/copilot-instructions.md",
    ".github/instructions/*.instructions.md",
    ".github/skills/README.md",
    ".github/skills/*/SKILL.md"
  ],
  "expected_skill_names": {
    ".agents/skills": [
      "agent-guidance-boundary-guard",
      "agentic-pdca-loop",
      "allure-extent-report-operator",
      "ci-failure-investigator",
      "flaky-test-stabilizer",
      "framework-source-rules",
      "graphify",
      "java-test-rules",
      "mcp-transport-contract-auditor",
      "modular-boundary-auditor",
      "public-behavior-docs-synchronizer",
      "release-dependency-guard",
      "shaft-marketing-ad-producer",
      "shaft-ui-design"
    ],
    ".claude/skills": [
      "act-as-fable",
      "caveman",
      "graphify",
      "ponytail",
      "shaft-mastery",
      "test-driven-development",
      "work-github"
    ],
    ".github/skills": [
      "agent-guidance-boundary-guard",
      "agentic-pdca-loop",
      "allure-extent-report-operator",
      "ci-failure-investigator",
      "flaky-test-stabilizer",
      "mcp-transport-contract-auditor",
      "modular-boundary-auditor",
      "public-behavior-docs-synchronizer",
      "release-dependency-guard",
      "shaft-marketing-ad-producer",
      "shaft-ui-design"
    ]
  },
  "skill_budgets": {
    ".agents/skills": {
      "max_description_chars": 220,
      "max_body_chars": 300,
      "require_openai_yaml": true
    },
    ".claude/skills": {
      "max_skill_md_bytes": 16384
    },
    ".github/skills": {
      "max_skill_md_bytes": 4096
    }
  },
  "reference_scan_globs": [
    "AGENTS.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
    ".agents/skills/*/SKILL.md",
    ".claude/skills/*/SKILL.md",
    ".github/copilot-instructions.md",
    ".github/instructions/*.instructions.md",
    ".github/skills/README.md",
    ".github/skills/*/SKILL.md",
    ".github/pull_request_template.md"
  ],
  "scope_files": [
    ".github/instructions/framework-source.instructions.md",
    ".github/instructions/java-tests.instructions.md"
  ],
  "skills_roots": [
    ".agents/skills",
    ".claude/skills",
    ".github/skills"
  ],
  "duplicate_paragraph_min_chars": 180,
  "forbidden_patterns": [
    {
      "pattern": "(?i)at least three (?:full )?pdca",
      "message": "mandatory repeated PDCA cycles"
    },
    {
      "pattern": "(?i)minimum 3[- ]iteration",
      "message": "mandatory repeated implementation iterations"
    },
    {
      "pattern": "(?i)before every commit",
      "message": "per-commit validation ceremony"
    },
    {
      "pattern": "(?i)capture screenshots? of (?:test|passing)",
      "message": "routine screenshot evidence"
    },
    {
      "pattern": "(?i)mandatory for non-trivial sessions",
      "message": "automatic session-memory updates"
    },
    {
      "pattern": "(?i)open a draft pr before",
      "message": "automatic remote PR creation"
    }
  ],
  "stale_references": [
    ".github/copilot-memory.md",
    "COPILOT_SETUP_VERIFICATION.md",
    "docs/AGENT_KNOWLEDGE_MIGRATION.md",
    "scripts/ai/orchestrate_models.py",
    "tests/scripts/test_orchestrate_models.py",
    ".github/skills/github-copilot/",
    ".github/skills/google-gemma/",
    ".github/skills/claude-code/",
    ".github/skills/deepseek/",
    ".github/skills/qwen/"
  ],
  "notes": "Principle (#3745): each guidance surface is bounded by its own load cost, not a shared global pool. Always-loaded files (AGENTS.md, CLAUDE.md, copilot instructions, skill name/description metadata) are bounded by max_estimated_tokens_per_host, since every host pays that cost every session. Trigger-loaded skill bodies are bounded per skill by skill_budgets[<root>].max_skill_md_bytes (.claude/skills 16384, .github/skills 4096 -- each matched to that host's actual per-skill load cost) so growing one skill never taxes another's budget. The .agents bridge stays on its own thinness caps (max_description_chars/max_body_chars), since those bodies are Codex-loaded metadata, not lazy on-demand content. Content quality within any cap is governed by the duplicate-paragraph and forbidden-pattern intent guards, never by a shared byte pool. Environmental gotcha (applies to every byte check above, including the per-skill cap): measure LF-normalized bytes, i.e. len(read_text().encode()) not raw stat().st_size -- Path.read_text() already collapses CRLF, matching the LF blobs CI checks out, so this avoids inflating the count with Windows-CRLF working-tree line endings that CI never sees."
}
