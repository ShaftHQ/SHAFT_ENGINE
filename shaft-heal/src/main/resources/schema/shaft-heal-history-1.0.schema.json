{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shafthq.github.io/schema/shaft-heal-history-1.0.schema.json",
  "title": "SHAFT Heal History",
  "type": "object",
  "required": [
    "schemaVersion",
    "records"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schemaVersion",
          "key",
          "pageKey",
          "originalLocator",
          "context",
          "fingerprint",
          "visualReference",
          "updatedAt",
          "checksum"
        ]
      }
    }
  },
  "additionalProperties": false
}
