{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shafthq.github.io/schema/shaft-execution-intelligence-1.0.schema.json",
  "title": "SHAFT Execution Intelligence",
  "type": "object",
  "required": [
    "schemaVersion",
    "bundleId",
    "totalAllureResults",
    "failingAttempts",
    "hiddenRetryFailures",
    "recurringFailures",
    "primaryCause",
    "confidence",
    "summary"
  ],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "bundleId": {"type": "string"},
    "totalAllureResults": {"type": "integer", "minimum": 0},
    "failingAttempts": {"type": "integer", "minimum": 0},
    "hiddenRetryFailures": {"type": "integer", "minimum": 0},
    "recurringFailures": {"type": "integer", "minimum": 0},
    "primaryCause": {"type": "string"},
    "confidence": {"type": "string"},
    "summary": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
