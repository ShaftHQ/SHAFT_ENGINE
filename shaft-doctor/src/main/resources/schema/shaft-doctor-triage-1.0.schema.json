{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shafthq.github.io/schema/shaft-doctor-triage-1.0.schema.json",
  "title": "SHAFT Doctor Triage",
  "type": "object",
  "required": [
    "schemaVersion",
    "bundleId",
    "totalAllureResults",
    "failingAttempts",
    "hiddenRetryFailures",
    "recurringFailures",
    "primarySignature",
    "summary",
    "evidenceIds"
  ],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "bundleId": {"type": "string"},
    "totalAllureResults": {"type": "integer", "minimum": 0},
    "failingAttempts": {"type": "integer", "minimum": 0},
    "hiddenRetryFailures": {"type": "integer", "minimum": 0},
    "recurringFailures": {"type": "integer", "minimum": 0},
    "primarySignature": {"type": "string"},
    "summary": {"type": "string", "minLength": 1},
    "evidenceIds": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
